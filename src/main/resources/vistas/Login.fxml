<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controlador.LoginController"
            style="-fx-background-color: linear-gradient(to bottom right, #1f2937, #111827);">

    <center>

        <VBox spacing="15" alignment="CENTER"
              style="
                -fx-background-color: white;
                -fx-padding: 35;
                -fx-background-radius: 15;
                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 15, 0.3, 0, 5);
              "
              maxWidth="320">

            <!-- TITULO -->
            <Label text="☕ LOGIN CAFETERÍA"
                   style="-fx-font-size:20px; -fx-font-weight:bold;"/>

            <Label text="Ingresa tus credenciales"
                   style="-fx-text-fill:gray;"/>

            <!-- USUARIO -->
            <TextField fx:id="campoUsuario"
                       promptText="Usuario"
                       prefWidth="250"
                       style="
                         -fx-background-radius: 10;
                         -fx-border-radius: 10;
                         -fx-border-color: #d1d5db;
                       "/>

            <!-- ROL -->
            <ComboBox fx:id="comboRol"
                      promptText="Selecciona rol"
                      prefWidth="250"
                      style="
                        -fx-background-radius: 10;
                        -fx-border-radius: 10;
                        -fx-border-color: #d1d5db;
                      "/>

            <!-- PASSWORD -->
            <PasswordField fx:id="campoPassword"
                           promptText="Contraseña"
                           prefWidth="250"
                           style="
                             -fx-background-radius: 10;
                             -fx-border-radius: 10;
                             -fx-border-color: #d1d5db;
                           "/>

            <!-- BOTÓN -->
            <Button text="INGRESAR"
                    onAction="#handleLogin"
                    prefWidth="250"
                    style="
                        -fx-background-color: #22c55e;
                        -fx-text-fill: white;
                        -fx-font-weight: bold;
                        -fx-background-radius: 10;
                    "/>

            <!-- ERROR -->
            <Label fx:id="etiquetaError"
                   textFill="red"
                   visible="false"/>

        </VBox>

    </center>

</BorderPane>